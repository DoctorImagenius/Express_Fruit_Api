<body>
    <div>
        These are the fresh fruits
    </div>
   <% fruits.forEach((fruit) => {%>
    <div style="background-color: bisque; color: <%= fruit.color %>; padding: 10px; margin: 10px; border-radius: 10px">
        <h2>
        Name : <%= fruit.name %>
    </h2>
    <h2>
        Color : <%= fruit.color %>
    </h2>
    </div>
   <%})%>

</body>